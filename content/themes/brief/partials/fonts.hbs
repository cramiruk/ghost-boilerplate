{{!-- Typography --}}
{{#match @custom.font_headings "!=" "System"}}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{{else match @custom.font_body "!=" "System"}}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
{{/match}}

{{!-- Headings --}}
{{#match @custom.font_headings "Bodoni Moda"}}
  {{> font-loader font_headings=@custom.font_headings fallback="serif"}}
{{/match}}
{{#match @custom.font_headings "Bricolage Grotesque"}}
  {{> font-loader font_headings=@custom.font_headings fallback="sans-serif"}}
{{/match}}
{{#match @custom.font_headings "DM Sans"}}
  {{> font-loader font_headings=@custom.font_headings fallback="sans-serif"}}
{{/match}}
{{#match @custom.font_headings "Funnel Sans"}}
  {{> font-loader font_headings=@custom.font_headings fallback="sans-serif"}}
{{/match}}
{{#match @custom.font_headings "Geist"}}
  {{> font-loader font_headings=@custom.font_headings fallback="sans-serif"}}
{{/match}}
{{#match @custom.font_headings "Hanken Grotesk"}}
  {{> font-loader font_headings=@custom.font_headings fallback="sans-serif"}}
{{/match}}
{{#match @custom.font_headings "Inter"}}
  {{> font-loader font_headings=@custom.font_headings fallback="sans-serif"}}
{{/match}}
{{#match @custom.font_headings "PT Serif"}}
  {{> font-loader font_headings=@custom.font_headings fallback="serif"}}
{{/match}}
{{#match @custom.font_headings "Spectral"}}
  {{> font-loader font_headings=@custom.font_headings fallback="serif"}}
{{/match}}

