
<nav class="{{nav_class}}" data-socials="{{data_value}}" x-data="socials">

  {{!-- Facebook --}}
  {{#if @site.facebook}}
    <a href="{{social_url type="facebook"}}" class="{{item_class}}" aria-label="Facebook">{{>icon name="brand-facebook" icon_class=icon_class}}<span class="{{text_class}}">Facebook</span></a>
  {{/if}}

  {{!-- Twitter --}}
  {{#if @site.twitter}}
    <a href="{{social_url type="twitter"}}" class="{{item_class}}" aria-label="Twitter">{{>icon name="brand-x" icon_class=icon_class}}<span class="{{text_class}}">Twitter</span></a>
  {{/if}}

  {{!-- Bluesky --}}
  <a :href="bluesky" :class="bluesky && 'block!'" class="hidden {{item_class}}" aria-label="Bluesky">{{>icon name="brand-bluesky" icon_class=icon_class}}<span class="{{text_class}}">Bluesky</span></a>

  {{!-- Discord --}}
  <a :href="discord" :class="discord && 'block!'" class="hidden {{item_class}}" aria-label="Discord">{{>icon name="brand-discord" icon_class=icon_class}}<span class="{{text_class}}">Discord</span></a>

  {{!-- Github --}}
  <a :href="github" :class="github && 'block!'" class="hidden {{item_class}}" aria-label="Github">{{>icon name="brand-github" icon_class=icon_class}}<span class="{{text_class}}">Github</span></a>

  {{!-- Instagram --}}
  <a :href="instagram" :class="instagram && 'block!'" class="hidden {{item_class}}" aria-label="Instagram">{{>icon name="brand-instagram" icon_class=icon_class}}<span class="{{text_class}}">Instagram</span></a>

  {{!-- Linkedin --}}
  <a :href="linkedin" :class="linkedin && 'block!'" class="hidden {{item_class}}" aria-label="Linkedin">{{>icon name="brand-linkedin" icon_class=icon_class}}<span class="{{text_class}}">Linkedin</span></a>

  {{!-- Mastodon --}}
  <a :href="mastodon" :class="mastodon && 'block!'" class="hidden {{item_class}}" aria-label="Mastodon">{{>icon name="brand-mastodon" icon_class=icon_class}}<span class="{{text_class}}">Mastodon</span></a>

  {{!-- Pinterest --}}
  <a :href="pinterest" :class="pinterest && 'block!'" class="hidden {{item_class}}" aria-label="Pinterest">{{>icon name="brand-pinterest" icon_class=icon_class}}<span class="{{text_class}}">Pinterest</span></a>

  {{!-- Reddit --}}
  <a :href="reddit" :class="reddit && 'block!'" class="hidden {{item_class}}" aria-label="Reddit">{{>icon name="brand-reddit" icon_class=icon_class}}<span class="{{text_class}}">Reddit</span></a>

  {{!-- Telegram --}}
  <a :href="telegram" :class="telegram && 'block!'" class="hidden {{item_class}}" aria-label="Telegram">{{>icon name="brand-telegram" icon_class=icon_class}}<span class="{{text_class}}">Telegram</span></a>

  {{!-- Threads --}}
  <a :href="threads" :class="threads && 'block!'" class="hidden {{item_class}}" aria-label="Threads">{{>icon name="brand-threads" icon_class=icon_class}}<span class="{{text_class}}">Threads</span></a>

  {{!-- Tiktok --}}
  <a :href="tiktok" :class="tiktok && 'block!'" class="hidden {{item_class}}" aria-label="Tiktok">{{>icon name="brand-tiktok" icon_class=icon_class}}<span class="{{text_class}}">Tiktok</span></a>

  {{!-- Whatsapp --}}
  <a :href="whatsapp" :class="whatsapp && 'block!'" class="hidden {{item_class}}" aria-label="Whatsapp">{{>icon name="brand-whatsapp" icon_class=icon_class}}<span class="{{text_class}}">Whatsapp</span></a>

  {{!-- Youtube --}}
  <a :href="youtube" :class="youtube && 'block!'" class="hidden {{item_class}}" aria-label="Youtube">{{>icon name="brand-youtube" icon_class=icon_class}}<span class="{{text_class}}">Youtube</span></a>

  {{!-- RSS --}}
  <a :href="rss" :class="rss && 'block!'" class="hidden {{item_class}}" aria-label="RSS">{{>icon name="rss" icon_class=icon_class}}<span class="{{text_class}}">RSS</span></a>

</nav>

{{#contentFor "scripts"}}
  <script>
    window.socials = {
      bluesky: '',
      discord: '',
      github: '',
      instagram: '',
      linkedin: '',
      mastodon: '',
      pinterest: '',
      reddit: '',
      telegram: '',
      threads: '',
      tiktok: '',
      whatsapp: '',
      youtube: '',
      rss: '/rss'
    }

    document.addEventListener('alpine:init', () => {
      Alpine.data('socials', () => (window.socials))
    })
  </script>
{{/contentFor}}