{{!-- ============================================================
      Vecstrata kinetic hero. Markup/styles from the design ref
      (assets/css/hero.css + assets/js/hero.js, loaded in home.hbs).
      Brief's own nav/header stays; only the hero body lives here.
      Edit copy below: eyebrow text, the rotating data-words, the
      static headline lines, the .vs-sub paragraph, button labels.
      ============================================================ --}}
<section class="vs-hero">
  <div class="vs-hero__inner">

    {{!-- Eyebrow (the line above the headline) --}}
    <div class="vs-eyebrow">Market intelligence, weekly</div>

    {{!-- Headline with rotating word. Edit terms in data-words;
          data-interval is ms per word. --}}
    <h1 class="vs-headline" aria-label="See where capital moves next.">
      <span class="vs-headline__line">See where <span class="vs-rotate" data-words="capital,talent,attention,margin" data-interval="1800" aria-hidden="true"><span class="vs-rotate__word">capital</span></span></span>
      <span class="vs-headline__line">moves next.</span>
    </h1>

    {{!-- Subheader --}}
    <p class="vs-sub">
      We catch the shift early — and show the reasoning, so you can act on it
      before the rest of the market does.
    </p>

    {{!-- Buttons. Primary links to the latest issue, ghost to the archive. --}}
    <div class="vs-cta">
      {{#get "posts" limit="1" as |latest|}}
        {{#foreach latest}}
          <a class="vs-btn vs-btn--primary" href="{{url}}">Read this week's issue</a>
        {{/foreach}}
      {{/get}}
      <a class="vs-btn vs-btn--ghost" href="/archive/">Browse the archive</a>
    </div>

  </div>
</section>
