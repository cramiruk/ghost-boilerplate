{{!-- ============================================================
      Vecstrata kinetic hero. Styles/JS: assets/css/hero.css +
      assets/js/hero.js (loaded in home.hbs). Brief's own nav stays.

      Editable in Ghost Admin → Design → Homepage:
        • Eyebrow line        → "hero_eyebrow"
        • Headline lead text  → "hero_headline"          (e.g. "See where")
        • Rotating words      → "hero_rotating_words"     (comma-separated)
        • Headline suffix     → "hero_headline_suffix"    (the fixed line)
        • Subheading          → "hero_subheading"
      The suffix is a separate fixed line so it doesn't shift while
      the word above it rotates.
      ============================================================ --}}
<section class="vs-hero">
  <div class="vs-hero__inner">

    {{!-- Eyebrow (the line above the headline) --}}
    {{#if @custom.hero_eyebrow}}
      <div class="vs-eyebrow">{{@custom.hero_eyebrow}}</div>
    {{/if}}

    {{!-- Headline: lead text + rotating words + fixed suffix line, all from settings --}}
    <h1 class="vs-headline" aria-label="{{@custom.hero_headline}} {{@custom.hero_headline_suffix}}">
      <span class="vs-headline__line">{{@custom.hero_headline}} <span class="vs-rotate" data-words="{{@custom.hero_rotating_words}}" data-interval="1800" aria-hidden="true"><span class="vs-rotate__word"></span></span></span>
      <span class="vs-headline__line">{{@custom.hero_headline_suffix}}</span>
    </h1>

    {{!-- Subheader (Ghost: Hero subheading), with fallback --}}
    {{#if @custom.hero_subheading}}
      <p class="vs-sub">{{{@custom.hero_subheading}}}</p>
    {{else}}
      <p class="vs-sub">We catch the shift early — and show the reasoning, so you can act on it before the rest of the market does.</p>
    {{/if}}

    {{!-- Buttons: primary → latest issue, secondary → Issues tag (same as nav) --}}
    <div class="vs-cta">
      {{!-- Latest issue-tagged post, excluding backtests --}}
      {{#get "posts" filter="tag:issue+tag:-backtest" limit="1" as |latest|}}
        {{#foreach latest}}
          <a class="vs-btn vs-btn--primary" href="{{url}}">Read the latest issue</a>
        {{/foreach}}
      {{/get}}
      <a class="vs-btn vs-btn--ghost" href="/tag/issue/">Browse all issues</a>
    </div>

  </div>
</section>
