{
  "name": "brief",
  "description": "Brief Ghost Theme",
  "version": "1.6.0",
  "engines": {
    "ghost": ">=6.0.0"
  },
  "type": "module",
  "author": {
    "name": "Bright Themes",
    "email": "hi@brightthemes.com",
    "url": "https://brightthemes.com"
  },
  "gpm": {
    "type": "theme",
    "categories": [
      "Blog"
    ]
  },
  "keywords": [
    "ghost",
    "theme",
    "ghost-theme"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/brightthemes/brief.git"
  },
  "scripts": {
    "dev": "vite build --watch & vite",
    "serve": "vite",
    "watch": "vite build --watch",
    "prebuild": "test -f theme.js && node theme.js || true",
    "build": "vite build",
    "preview": "vite preview",
    "test": "gscan . --verbose",
    "zip": "npm run build && npm run test && mkdir -p dist && zip -rq dist/${npm_package_name} . -x 'dist*' 'demo*' 'node_modules*' '.*' 'TODO.md' 'private.hbs' 'theme.js' && size_kb=$(node -p \"Math.ceil(require('fs').statSync('dist/' + process.env.npm_package_name + '.zip').size / 1024)\") && printf '\\n\\033[1m\\033[32m✓\\033[39m Created dist/%s.zip (%s kB)\\033[0m\\n' \"${npm_package_name}\" \"$size_kb\"",
    "release": "npm version minor --no-git-tag-version && npm run zip && git add . && git commit -m \"v$(node -p 'require(\"./package.json\").version')\" && git push"
  },
  "dependencies": {
    "@glidejs/glide": "^3.7.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.2",
    "@tryghost/content-api": "^1.12.6",
    "@vitejs/plugin-legacy": "^5.4.3",
    "alpinejs": "^3.15.9",
    "fitvids": "^2.1.1",
    "gscan": "^5.4.0",
    "postcss": "^8.5.8",
    "postcss-mixins": "^9.0.4",
    "tailwindcss": "^4.1.5",
    "tocbot": "^4.36.4",
    "vite": "^5.4.21"
  },
  "config": {
    "card_assets": true,
    "posts_per_page": 12,
    "image_sizes": {
      "xxs": {
        "width": 30
      },
      "xs": {
        "width": 100
      },
      "s": {
        "width": 320
      },
      "m": {
        "width": 640
      },
      "l": {
        "width": 960
      },
      "xl": {
        "width": 1280
      },
      "xxl": {
        "width": 2000
      }
    },
    "custom": {
      "color_scheme": {
        "type": "select",
        "options": [
          "system",
          "light",
          "dark"
        ],
        "default": "system",
        "description": "Set the default color scheme of the site"
      },
      "color_scheme_toggle_position": {
        "type": "select",
        "options": [
          "header",
          "footer",
          "header & footer",
          "hidden"
        ],
        "default": "footer",
        "description": "Set the color scheme toggle position"
      },
      "font_headings": {
        "type": "select",
        "options": [
          "System",
          "Bodoni Moda",
          "Bricolage Grotesque",
          "DM Sans",
          "Funnel Sans",
          "Geist",
          "Hanken Grotesk",
          "Inter",
          "PT Serif",
          "Spectral"
        ],
        "default": "Geist",
        "description": "Set the heading font (when the Ghost 'Heading font' is set to theme default)"
      },
      "font_body": {
        "type": "select",
        "options": [
          "System",
          "Bodoni Moda",
          "Bricolage Grotesque",
          "DM Sans",
          "Funnel Sans",
          "Geist",
          "Hanken Grotesk",
          "Inter",
          "PT Serif",
          "Spectral"
        ],
        "default": "Geist",
        "description": "Set the body font (when the Ghost 'Body font' is set to theme default)"
      },
      "dark_theme_logo": {
        "type": "image",
        "description": "Logo for the dark theme"
      },
      "header_cta_text": {
        "type": "text",
        "description": "Set the header call-to-action text"
      },
      "header_cta_url": {
        "type": "text",
        "description": "Set the header call-to-action link"
      },
      "post_feed_style": {
        "type": "select",
        "options": [
          "detailed",
          "minimal"
        ],
        "default": "detailed",
        "description": "Set the post feed style for the homepage, tag and author pages"
      },
      "show_header_and_footer": {
        "type": "boolean",
        "default": true,
        "description": "Show the header on the homepage",
        "group": "homepage"
      },
      "hero_headline": {
        "type": "text",
        "default": "See where",
        "description": "Homepage hero: headline text before the rotating word (e.g. 'See where'). The fixed 'moves next.' line and eyebrow are in partials/sections/hero.hbs.",
        "group": "homepage"
      },
      "hero_rotating_words": {
        "type": "text",
        "default": "capital,talent,attention,margin",
        "description": "Homepage hero: comma-separated words that rotate in the headline",
        "group": "homepage"
      },
      "hero_subheading": {
        "type": "text",
        "description": "Set the homepage hero subheading",
        "group": "homepage"
      },
      "hero_text_alignment": {
        "type": "select",
        "options": [
          "left",
          "center"
        ],
        "default": "left",
        "description": "Set the text alignment for the headline & subheading",
        "group": "homepage"
      },
      "hero_cover_image_style": {
        "type": "select",
        "options": [
          "left-side",
          "right-side",
          "none"
        ],
        "default": "none",
        "description": "Set the cover image style for the hero section",
        "group": "homepage"
      },
      "hero_subscribe_style": {
        "type": "select",
        "options": [
          "inline",
          "section",
          "inline+section",
          "none"
        ],
        "default": "inline",
        "description": "Set the subscribe action style for the hero section",
        "group": "homepage"
      },
      "show_featured_issues": {
        "type": "boolean",
        "default": false,
        "description": "Show the featured issues section as an inbox",
        "group": "homepage"
      },
      "show_latest_issues": {
        "type": "boolean",
        "default": true,
        "description": "Show the latest issues section",
        "group": "homepage"
      },
      "show_recommendations": {
        "type": "boolean",
        "default": true,
        "description": "Show a recommendations alongside the latest posts section",
        "group": "homepage"
      },
      "show_link_to_archive": {
        "type": "boolean",
        "default": true,
        "description": "Show a link to the archive page after the latest issues",
        "group": "homepage"
      },
      "default_post_template": {
        "type": "select",
        "options": [
          "email-format",
          "web-format"
        ],
        "default": "web-format",
        "group": "post",
        "description": "Set the default template for your posts"
      }
    }
  }
}
